# ─────────────────────────────────────────────────────────────────
# Community Hero – Environment Variables Example
# Copy relevant sections to each service's .env file
# ─────────────────────────────────────────────────────────────────

# ── App (server/.env) ─────────────────────────────────────────────
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# ── MongoDB ────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://admin:YourPassword@cluster0.xxxxx.mongodb.net/communityhero?retryWrites=true&w=majority

# ── Redis (optional — app works without it) ────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ────────────────────────────────────────────────────────────
JWT_SECRET=generate_random_64_char_string_here_abcdefgh1234567890abcdefgh1234
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=another_random_64_char_string_here_abcdefgh1234567890abcd
JWT_REFRESH_EXPIRES_IN=30d

# ── Google OAuth2 ──────────────────────────────────────────────────
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# ── Google AI (Gemini) ─────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Cloudinary (image uploads) ─────────────────────────────────────
# Get from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Nodemailer / SMTP (optional) ───────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
EMAIL_FROM=Community Hero <noreply@communityhero.app>

# ── Twilio SMS (optional) ──────────────────────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+1234567890

# ── Mapbox ─────────────────────────────────────────────────────────
# Get from: https://account.mapbox.com/access-tokens/
MAPBOX_ACCESS_TOKEN=your_mapbox_public_token

# ── Rate Limiting ──────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ── Session ────────────────────────────────────────────────────────
SESSION_SECRET=your_session_secret_change_in_production

# ─────────────────────────────────────────────────────────────────
# FRONTEND (client/.env)
# ─────────────────────────────────────────────────────────────────
# VITE_API_URL=http://localhost:5000
# VITE_SOCKET_URL=http://localhost:5000
# VITE_MAPBOX_TOKEN=your_mapbox_public_token

# ─────────────────────────────────────────────────────────────────
# ML SERVICE (ml-service/.env)
# ─────────────────────────────────────────────────────────────────
# GEMINI_API_KEY=your_gemini_api_key_here
# KAFKA_BOOTSTRAP_SERVERS=localhost:9092


# ── App ───────────────────────────────────
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# ── MongoDB ───────────────────────────────
MONGO_URI=mongodb://admin:secret@localhost:27017/community_hero?authSource=admin

# ── Redis ─────────────────────────────────
REDIS_URL=redis://:redissecret@localhost:6379

# ── JWT ───────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_key_change_in_production
JWT_REFRESH_EXPIRES_IN=30d

# ── Google OAuth2 ─────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# ── Cloudinary (image storage) ────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Nodemailer (SMTP) ─────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=Community Hero <noreply@communityhero.app>

# ── Twilio (SMS) ──────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+1234567890

# ── Mapbox ────────────────────────────────
MAPBOX_ACCESS_TOKEN=your_mapbox_token

# ── Rate Limiting ─────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ── Session ───────────────────────────────
SESSION_SECRET=your_session_secret_change_in_production
