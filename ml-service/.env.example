# API Configuration
PORT=8000
ENVIRONMENT=development

# Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_INPUT_TOPIC=civic-issues-raw
KAFKA_OUTPUT_TOPIC=civic-issues-processed

# Model Paths (Fallback logic in code uses default web models if not found)
YOLO_MODEL_PATH=weights/yolov8n.pt
CNN_MODEL_PATH=weights/severity_cnn.pt
